{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      ".read": true,
      ".write": true
    },
    "saladOrders": {
      "rooms": {
        "$roomId": {
          "info": {
            ".read": "auth != null",
            ".write": "auth != null && ((!data.exists() && newData.child('managerUid').val() === auth.uid) || data.child('managerUid').val() === auth.uid)"
          },
          "orders": {
            ".read": "auth != null",
            "$userId": {
              ".write": "auth != null && ((auth.uid === $userId && root.child('saladOrders/rooms').child($roomId).child('info/status').val() === 'open') || root.child('saladOrders/rooms').child($roomId).child('info/managerUid').val() === auth.uid)"
            }
          }
        }
      }
    }
  }
}
